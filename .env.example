# Copy this file to .env.local for local development (never commit .env.local).
# In production, set these in your Vercel project's Environment Variables instead.

# Required. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional, defaults to gemini-2.0-flash if unset.
GEMINI_MODEL=gemini-2.0-flash
